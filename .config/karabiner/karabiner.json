{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Hyper + uiojkl로 단축키로 마우스 제어",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "u",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "pointing_button": "button1" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "o",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "pointing_button": "button2" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "j",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "mouse_key": { "x": -1000 } }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "i",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "mouse_key": { "y": -1000 } }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "k",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "mouse_key": { "y": 1000 } }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "mouse_key": { "x": 1000 } }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+t -> Open terminal",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "software_function": {
                                            "open_application": {
                                                "bundle_identifier": "com.googlecode.iterm2",
                                                "file_path": "/Applications/iTerm.app"
                                            }
                                        }
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+d → 복사 후 gemini 실행",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "d",
                                    "modifiers": {
                                        "mandatory": ["left_shift", "left_command", "left_control", "left_option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "c",
                                        "modifiers": ["left_command"]
                                    },
                                    { "shell_command": "open -a 'Google Gemini'" }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+k -> Open KakaoTalk (shell_command)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "k",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'KakaoTalk.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+n -> Open Notion",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "n",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'Notion.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+f → Finder 실행/활성화",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "shell_command": "open -a 'Finder.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper Series Hyper+g → Gmail, Hyper+c -> calendar",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "g",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "shell_command": "open -a 'gmail.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "shell_command": "open -a 'Google Calendar.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+[1-4] → launch apps (firefox, Chrome, Gemini, safari)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "1",
                                    "modifiers": {
                                        "mandatory": ["left_shift", "left_command", "left_control", "left_option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "c",
                                        "modifiers": ["left_command"]
                                    },
                                    { "shell_command": "open -a 'firefox'" }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "2",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock", "any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'Google Chrome.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "3",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock", "any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'Google Gemini'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "4",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["caps_lock", "any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'safari.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + m -> YouTube Music",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "m",
                                    "modifiers": {
                                        "mandatory": ["left_command", "left_control", "left_option", "left_shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a 'YouTube Music.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+P : Open Chrome Password Manager",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "p",
                                    "modifiers": { "mandatory": ["command", "control", "option", "shift"] }
                                },
                                "to": [{ "shell_command": "open -a 'Google Password Manager'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+S to Command+V",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "s",
                                    "modifiers": { "mandatory": ["left_control", "left_shift", "left_command", "left_option"] }
                                },
                                "to": [
                                    {
                                        "key_code": "v",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "한/영 입력 소스 전환: right_command -> hyper + ]",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "mandatory": [] }
                                },
                                "to": [
                                    {
                                        "key_code": "close_bracket",
                                        "modifiers": ["left_shift", "left_control", "left_option", "left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper+E 복사 후 Naver 영어사전 검색(외부 AppleScript)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "e",
                                    "modifiers": { "mandatory": ["left_shift", "left_command", "left_control", "left_option"] }
                                },
                                "to": [
                                    {
                                        "key_code": "c",
                                        "modifiers": ["left_command"]
                                    },
                                    { "shell_command": "osascript ~/scripts/safari_naver_dict.scpt" }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "manipulators": [
                            {
                                "description": "Change caps_lock to command+control+option+shift.",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
